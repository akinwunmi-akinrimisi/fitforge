# ═══════════════════════════════════════════════════
# FitForge90 — Environment Variables (project-scoped)
# Copy this file to .env.local for development.
# NEVER commit .env or .env.local.
# ═══════════════════════════════════════════════════

# --- Supabase (self-hosted on VPS) ---
# Public URL — safe to expose in the browser bundle
NEXT_PUBLIC_SUPABASE_URL=https://supabase.operscale.cloud
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER expose to the browser. Used for:
#  - seed / migration scripts
#  - Server Actions that need to bypass RLS (very rare — prefer RLS-aware flows)
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret for verifying Supabase session tokens on the server
SUPABASE_JWT_SECRET=

# Direct Postgres URL for migrations (server-only, never bundled)
# Format: postgresql://USER:PASSWORD@HOST:5432/postgres
POSTGRES_URL=

# --- Cron / scheduled jobs ---
# Shared secret gating /api/cron/* endpoints against external cron callers
CRON_SHARED_SECRET=

# --- App ---
# Public site URL (used for auth callbacks, OG images, etc.)
NEXT_PUBLIC_SITE_URL=https://fitforge.operscale.cloud

# Timezone for all user-facing times (DB stays in UTC)
NEXT_PUBLIC_APP_TZ=Africa/Lagos

# --- Bootstrap / seed ---
# Email of the auth.users row that owns the single-tenant plan.
# Provisioned automatically by `pnpm seed` if absent.
FITFORGE_OWNER_EMAIL=

# --- Transactional email (M4+) ---
# Resend API for weekly adaptation summaries.
RESEND_API_KEY=
RESEND_SENDER=

# --- Web Push (M6.6) ---
# Generate once with: node -e "console.log(require('web-push').generateVAPIDKeys())"
# The public key must ALSO be mirrored to NEXT_PUBLIC_VAPID_PUBLIC_KEY so the
# client can subscribe.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- Observability (optional, disabled by default) ---
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
